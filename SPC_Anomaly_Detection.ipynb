import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from scipy import stats
from sklearn.ensemble import IsolationForest

# ============================================
# 1. SIMULATE SEMICONDUCTOR ETCH PROCESS DATA
# ============================================
np.random.seed(42)
n_wafers = 200
baseline_etch_rate = 150  # nm/min
std_dev = 3

etch_data = pd.DataFrame({
    'Wafer_ID': np.arange(1, n_wafers + 1),
    'Etch_Rate_nm_min': np.random.normal(baseline_etch_rate, std_dev, n_wafers),
    'Temperature_C': np.random.normal(22, 1.5, n_wafers),
    'Pressure_mTorr': np.random.normal(50, 2, n_wafers)
})

# Inject anomalies (process excursion)
etch_data.loc[45:50, 'Etch_Rate_nm_min'] = [165, 168, 170, 158, 162, 160]  # upward drift
etch_data.loc[120:125, 'Etch_Rate_nm_min'] = [130, 128, 132, 135, 129, 131]  # downward shift

print("=" * 60)
print("SEMICONDUCTOR ETCH PROCESS SIMULATION")
print("=" * 60)
print(etch_data.head(10))
print(f"\nSummary Stats:\n{etch_data['Etch_Rate_nm_min'].describe()}")

# ============================================
# 2. STATISTICAL PROCESS CONTROL (SPC) - CONTROL CHART
# ============================================
mean_etch = etch_data['Etch_Rate_nm_min'].mean()
std_etch = etch_data['Etch_Rate_nm_min'].std()
ucl = mean_etch + 3 * std_etch   # Upper Control Limit
lcl = mean_etch - 3 * std_etch   # Lower Control Limit

plt.figure(figsize=(12, 5))
plt.plot(etch_data['Wafer_ID'], etch_data['Etch_Rate_nm_min'], 'o-', markersize=4, linewidth=0.8)
plt.axhline(mean_etch, color='green', linestyle='--', label=f'Mean = {mean_etch:.1f}')
plt.axhline(ucl, color='red', linestyle='--', label=f'UCL = {ucl:.1f}')
plt.axhline(lcl, color='red', linestyle='--', label=f'LCL = {lcl:.1f}')
plt.fill_between([0, 200], lcl, ucl, alpha=0.1, color='green')
plt.xlabel('Wafer ID')
plt.ylabel('Etch Rate (nm/min)')
plt.title('SPC Control Chart: Etch Process Monitoring')
plt.legend()
plt.grid(alpha=0.3)
plt.tight_layout()
plt.savefig('SPC_Control_Chart.png', dpi=150)
plt.show()

# ============================================
# 3. ANOMALY DETECTION (Isolation Forest - FDC parallel)
# ============================================
features = ['Etch_Rate_nm_min', 'Temperature_C', 'Pressure_mTorr']
model = IsolationForest(contamination=0.05, random_state=42)
etch_data['Anomaly'] = model.fit_predict(etch_data[features])
etch_data['Anomaly_Flag'] = etch_data['Anomaly'].apply(lambda x: 'Anomaly' if x == -1 else 'Normal')

anomalies = etch_data[etch_data['Anomaly_Flag'] == 'Anomaly']
print(f"\n{len(anomalies)} anomalies detected (5% contamination rate expected)")
print(anomalies)

plt.figure(figsize=(12, 5))
colors = {'Normal': 'blue', 'Anomaly': 'red'}
for flag, group in etch_data.groupby('Anomaly_Flag'):
    plt.scatter(group['Wafer_ID'], group['Etch_Rate_nm_min'], 
                c=colors[flag], label=flag, alpha=0.7, s=40)
plt.xlabel('Wafer ID')
plt.ylabel('Etch Rate (nm/min)')
plt.title('Fault Detection & Classification (FDC): Anomaly Detection')
plt.legend()
plt.grid(alpha=0.3)
plt.tight_layout()
plt.savefig('FDC_Anomaly_Detection.png', dpi=150)
plt.show()

# ============================================
# 4. ROOT CAUSE ANALYSIS (CAPA) - Correlation Analysis
# ============================================
correlation_matrix = etch_data[features].corr()
print("\nCorrelation Matrix (Root Cause Analysis):")
print(correlation_matrix)

plt.figure(figsize=(6, 5))
sns.heatmap(correlation_matrix, annot=True, cmap='coolwarm', center=0)
plt.title('Root Cause Analysis: Etch Rate vs. Process Parameters')
plt.tight_layout()
plt.savefig('Root_Cause_Correlation.png', dpi=150)
plt.show()

# ============================================
# 5. PROCESS CAPABILITY (CpK) CALCULATION
# ============================================
usl = 160  # Upper Spec Limit (nm/min)
lsl = 140  # Lower Spec Limit (nm/min)

# Exclude anomalies for baseline capability
normal_process = etch_data[etch_data['Anomaly_Flag'] == 'Normal']['Etch_Rate_nm_min']
cp = (usl - lsl) / (6 * normal_process.std())
cpk = min((normal_process.mean() - lsl) / (3 * normal_process.std()),
          (usl - normal_process.mean()) / (3 * normal_process.std()))

print("\n" + "=" * 60)
print("PROCESS CAPABILITY ANALYSIS (CpK)")
print("=" * 60)
print(f"Upper Spec Limit (USL): {usl} nm/min")
print(f"Lower Spec Limit (LSL): {lsl} nm/min")
print(f"Process Mean: {normal_process.mean():.1f} nm/min")
print(f"Process Std Dev: {normal_process.std():.2f}")
print(f"Cp: {cp:.2f}")
print(f"CpK: {cpk:.2f}")

if cpk >= 1.33:
    print("✅ Process is CAPABLE (CpK ≥ 1.33)")
else:
    print("⚠️ Process needs IMPROVEMENT (CpK < 1.33)")

# ============================================
# 6. SUMMARY REPORT (Simulated QEF/XRB Output)
# ============================================
print("\n" + "=" * 60)
print("QUALITY EVENT FORM (QEF) SUMMARY")
print("=" * 60)
print(f"Event Description: Etch rate excursion detected on Wafers 45-50 and 120-125")
print(f"Root Cause (hypothesis): Temperature instability + pressure drift (correlation = {correlation_matrix.loc['Temperature_C', 'Etch_Rate_nm_min']:.2f})")
print(f"CAPA Recommended:")
print("  1. Recalibrate temperature controller on chamber B")
print("  2. Implement real-time SPC alerts for ±3σ violations")
print("  3. Requalify etch process using 10 monitor wafers")
print(f"Disposition: Wafers 45-50 → Rework | Wafers 120-125 → Scrap")
print("Status: Closed - Corrective action implemented and verified")
